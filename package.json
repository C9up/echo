{
	"name": "@c9up/echo",
	"version": "0.1.3",
	"description": "Cache — pluggable cache contract with memory + Redis drivers for the Ream framework",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./provider": {
			"types": "./src/EchoProvider.ts",
			"import": "./src/EchoProvider.ts"
		},
		"./services/main": {
			"types": "./src/services/main.ts",
			"import": "./src/services/main.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run",
		"lint": "biome check src/",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@c9up/ream": "^0.1.0"
	},
	"devDependencies": {
		"@types/node": "^22.19.15",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"files": [
		"src",
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			},
			"./provider": {
				"types": "./dist/EchoProvider.d.ts",
				"import": "./dist/EchoProvider.js"
			},
			"./services/main": {
				"types": "./dist/services/main.d.ts",
				"import": "./dist/services/main.js"
			}
		},
		"access": "public"
	},
	"peerDependenciesMeta": {
		"@c9up/ream": {
			"optional": true
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/C9up/echo.git"
	}
}
