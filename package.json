{
	"name": "@c9up/echo",
	"version": "0.1.0",
	"description": "Cache — pluggable cache contract with memory + Redis drivers for the Ream framework",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"development": "./src/index.ts",
			"import": "./dist/index.js"
		},
		"./provider": {
			"types": "./dist/EchoProvider.d.ts",
			"development": "./src/EchoProvider.ts",
			"import": "./dist/EchoProvider.js"
		},
		"./services/main": {
			"types": "./dist/services/main.d.ts",
			"development": "./src/services/main.ts",
			"import": "./dist/services/main.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run",
		"lint": "biome check src/",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@c9up/ream": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.19.15",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"files": [
		"src",
		"dist",
		"README.md",
		"LICENSE"
	]
}
